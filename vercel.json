{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "."
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "^/((?!.*\\.).*)$",
      "dest": "/$1.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/job-government",
      "destination": "/jobs-government",
      "permanent": true
    },
    {
      "source": "/job-government.html",
      "destination": "/jobs-government.html",
      "permanent": true
    },
    {
      "source": "/job-private",
      "destination": "/jobs-private",
      "permanent": true
    },
    {
      "source": "/job-private.html",
      "destination": "/jobs-private.html",
      "permanent": true
    },
    {
      "source": "/jobsgovernment",
      "destination": "/jobs-government",
      "permanent": true
    },
    {
      "source": "/jobsgovernment.html",
      "destination": "/jobs-government.html",
      "permanent": true
    },
    {
      "source": "/jobsprivate",
      "destination": "/jobs-private",
      "permanent": true
    },
    {
      "source": "/jobsprivate.html",
      "destination": "/jobs-private.html",
      "permanent": true
    }
  ]
}
